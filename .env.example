# Postgres (Neon recommended — https://neon.tech, free tier is enough).
# DATABASE_URL is the pooled connection string used at runtime; DIRECT_URL
# is Neon's direct/unpooled connection string, used by Prisma for migrations.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL="https://sandbox.monnify.com"

ANTHROPIC_API_KEY=

# Deployed at https://oja-invoice.vercel.app — Monnify webhooks need a public
# URL to reach us, so localhost only works for local dev. Set this to the
# Vercel URL in the Vercel dashboard env vars (and keep it here as the
# local-dev default).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
